    },
    {
      "name": "2. Block 1% BSA 1 h",
      "amount": 1,
      "unit": "step"
    },
    {
      "name": "3. Standards + samples 2 h",
      "amount": 1,
      "unit": "step"
    },
    {
      "name": "4. Detection Ab (biotin) 1 h",
      "amount": 1,
      "unit": "step"
    },
    {
      "name": "5. Streptavidin-HRP 30 min",
      "amount": 1,
      "unit": "step"
    },
    {
      "name": "6. TMB substrate 15-30 min",
      "amount": 1,
      "unit": "step"
    },
    {
      "name": "7. Stop (2N H₂SO₄), read OD450",
      "amount": 1,
      "unit": "step"
    }
  ],
  "notes": {
