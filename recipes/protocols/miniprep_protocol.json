      "amount": 1,
      "unit": "step"
    },
    {
      "name": "3. 250 µL Buffer P2 裂解 (颠倒混匀)",
      "amount": 1,
      "unit": "step"
    },
    {
      "name": "4. 350 µL Buffer P3 中和 (颠倒混匀)",
      "amount": 1,
      "unit": "step"
    },
    {
      "name": "5. 13,000×g 离心 10 min",
      "amount": 1,
      "unit": "step"
    },
    {
      "name": "6. 转移上清至新管",
      "amount": 1,
      "unit": "step"
    },
    {
      "name": "7. 加 0.7 倍体积异丙醇沉淀",
      "amount": 1,
      "unit": "step"
    },
    {
      "name": "8. 13,000×g 离心 15 min",
      "amount": 1,
      "unit": "step"
    },
    {
      "name": "9. 70% 乙醇洗涤",
      "amount": 1,
      "unit": "step"
    },
    {
      "name": "10. 风干 → 30–50 µL TE/H₂O 溶解",
      "amount": 1,
      "unit": "step"
    }
