  "components": [
    {
      "name": "1. Harvest cells (floating + adherent)",
      "amount": 1,
      "unit": "step"
    },
    {
      "name": "2. Wash cold PBS, 300Г—g 5 min",
      "amount": 1,
      "unit": "step"
    },
    {
      "name": "3. Resuspend 1Г—10вҒө in 100 ВөL Binding Buffer",
      "amount": 1,
      "unit": "step"
    },
    {
      "name": "4. Add 5 ВөL FITC-Annexin V + 5 ВөL PI",
      "amount": 1,
      "unit": "step"
    },
    {
      "name": "5. Incubate 15 min RT dark",
      "amount": 1,
      "unit": "step"
    },
    {
      "name": "6. Add 400 ВөL Binding Buffer",
      "amount": 1,
      "unit": "step"
    },
    {
      "name": "7. Analyze by flow cytometry within 1 h",
      "amount": 1,
      "unit": "step"
    }
  ],
  "notes": {
    "en": "AVвҒ»/PIвҒ»=live; AVвҒә/PIвҒ»=early apoptosis; AVвҒә/PIвҒә=late apoptosis; AVвҒ»/PIвҒә=necrosis. CaClвӮӮ essential. Positive control: staurosporine 1 ВөM 6 h.",
    "zh": "AVвҒ»/PIвҒ»=жҙ»пјӣAVвҒә/PIвҒ»=ж—©жңҹеҮӢдәЎпјӣAVвҒә/PIвҒә=жҷҡжңҹеҮӢдәЎпјӣAVвҒ»/PIвҒә=еқҸжӯ»гҖӮйңҖеҗ« CaClвӮӮгҖӮйҳіжҖ§еҜ№з…§пјҡжҳҹеҪўеӯўиҸҢзҙ  1 ВөM 6 hгҖӮ"
  },
