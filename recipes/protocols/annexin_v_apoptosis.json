{
  "id": "annexin_v_apoptosis",
  "name": "Annexin V / PI Apoptosis Assay",
  "nameCn": "Annexin V / PI еҮӢдәЎжЈҖжөӢ",
  "category": "protocol",
  "tags": [
    "apoptosis",
