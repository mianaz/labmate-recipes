{
  "id": "np40_lysis",
  "name": "NP-40 Lysis Buffer",
  "category": "buffer",
  "tags": [
    "protein extraction",
    "cell lysis",
    "Co-IP",
    "mild"
  ],
  "components": [
    {
      "name": "Tris-HCl (pH 7.4)",
      "amount": 0.605,
      "unit": "g",
      "mw": 121.14,
      "note": "50 mM (or 5 mL of 1M)"
    },
    {
      "name": "NaCl",
      "amount": 0.877,
      "unit": "g",
      "mw": 58.44,
      "note": "150 mM"
    },
    {
      "name": "NP-40 (IGEPAL CA-630)",
      "amount": 1,
      "unit": "mL",
      "note": "1%"
    },
    {
      "name": "EDTA",
      "amount": 0.074,
      "unit": "g",
      "mw": 292.24,
      "note": "2 mM"
    },
    {
      "name": "ddH₂O",
      "amount": 100,
      "unit": "mL",
      "note": "定容"
    }
  ],
  "nameCn": "NP-40 裂解液",
  "notes": {
    "en": "Mild lysis buffer that preserves protein-protein interactions, ideal for Co-IP. NP-40 does not lyse the nuclear membrane. Add protease inhibitors fresh before use. Add phosphatase inhibitors for phosphoprotein detection.",
    "zh": "温和裂解液，保留蛋白-蛋白相互作用，适合 Co-IP。NP-40 不裂解核膜。使用前加蛋白酶抑制剂。可加磷酸酶抑制剂用于磷酸化蛋白检测。"
  },
  "ref": "Abcam Co-IP protocol; Sambrook & Russell (2001)",
  "discipline": [
    "protein",
    "cell"
  ],
  "storage": {
    "temperature": "4°C",
    "duration": "3 months",
    "sterile": "not_required",
    "notes": "Add protease inhibitors fresh"
  },
  "usage": {
    "en": "Mild non-ionic detergent lysis buffer for IP and Co-IP under native conditions.",
    "zh": "温和非离子去污剂裂解缓冲液，用于天然条件下的 IP 和 Co-IP。"
  },
  "volume": 500,
  "volumeUnit": "mL",
  "prepSteps": [
    {
      "step": "Combine Tris-HCl pH 7.4, NaCl, and NP-40 (1%) in ~400 mL ddH₂O."
    },
    {
      "step": "Add EDTA if desired (1 mM)."
    },
    {
      "step": "Stir until dissolved."
    },
    {
      "step": "Bring to final volume of 500 mL."
    },
    {
      "step": "Store at 4°C; add protease inhibitors fresh before use."
    }
  ],
  "crosslinks": [
    "immunoprecipitation",
    "coip_protocol",
    "wb_protocol",
    "subcellular_fractionation"
  ]
}
