      "mw": 209.24,
      "note": "50 mM"
    },
    {
      "name": "Tricine",
      "amount": 4.48,
      "unit": "g",
      "mw": 179.17,
      "note": "50 mM"
    },
    {
      "name": "Coomassie Blue G-250",
      "amount": 0.1,
      "unit": "g",
      "note": "0.02%"
    }
  ],
  "nameCn": "BN-PAGE 阴极缓冲液",
  "notes": {
    "en": "Do not adjust pH (~7.0). After the gel front has migrated ~1/3, switch to cathode buffer without CBB to reduce background.",
    "zh": "不调 pH (约 7.0)。电泳 1/3 后可换不含 CBB 的阴极缓冲液。"
  },
  "ref": "Wittig et al. (2006) Nat Protoc 1:418–428",
  "discipline": [
    "protein"
  ],
  "storage": {
    "temperature": "4°C",
    "duration": "1 week",
    "sterile": "not_required",
    "notes": "Prepare fresh; CBB G-250 degrades"
  },
  "usage": {
    "en": "Blue-native PAGE cathode buffer (CBB G-250) for membrane protein complex analysis.",
    "zh": "蓝色天然 PAGE 阴极缓冲液（CBB G-250），用于膜蛋白复合体分析。"
  },
  "volume": 1000,
  "volumeUnit": "mL",
  "prepSteps": [
    {
      "step": "Dissolve Tricine and Bis-Tris in ~800 mL ddH₂O."
    },
    {
      "step": "Add Coomassie Blue G-250 and stir until dissolved."
    },
    {
      "step": "Adjust pH to 7.0 if necessary."
    },
    {
      "step": "Bring to final volume of 1000 mL with ddH₂O."
    },
    {
      "step": "Store at 4°C protected from light."
    }
  ],
